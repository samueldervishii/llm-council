# Étude Frontend - Environment Configuration

# ==========================================
# API Connection (REQUIRED for production)
# ==========================================
VITE_API_BASE=http://localhost:8000
# Backend API URL. Change to your production API URL when deploying.
# Examples:
#   Local development: http://localhost:8000
#   Production: https://api.yourdomain.com

# ==========================================
# API Authentication
# ==========================================
VITE_API_KEY=
# Must match the API_KEY set in the backend .env
# Leave empty if backend API authentication is disabled

# ==========================================
# Frontend URL (for shareable links)
# ==========================================
VITE_FRONTEND_URL=
# Used to generate shareable session URLs
# Defaults to window.location.origin if not set
# Examples:
#   Production: https://yourdomain.com
#   Local: http://localhost:5173
